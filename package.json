{
  "name": "@cse/jobs-ui",
  "version": "0.1.0",
  "description": "Shared job listing components for CSE Connect websites",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./seo": {
      "types": "./dist/seo/index.d.ts",
      "import": "./dist/seo/index.js"
    },
    "./css/animated-border-glow.css": "./dist/css/animated-border-glow.css",
    "./css/card-hover.css": "./dist/css/card-hover.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp -r src/css dist/css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "date-fns": "^4",
    "next": ">=15",
    "nuqs": "^2",
    "react": "^19"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "date-fns": "^4.1.0",
    "next": "^16.0.0",
    "nuqs": "^2.8.0",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cse-connect/cse-jobs-ui.git"
  },
  "license": "UNLICENSED"
}
